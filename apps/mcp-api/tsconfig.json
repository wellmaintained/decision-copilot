{
  "extends": "@decision-copilot/config-typescript/node.json",
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "lib"]
}