{
  "name": "webapp",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pre:push": "pnpm run lint && pnpm run test:unit && pnpm run build",
    "dev": "concurrently -n \"emulators,next\" \"pnpm run dev:emulators:with-data\" \"wait-on -l tcp:4400 -t 30000 && pnpm run dev:next\"",
    "dev:next": "next dev --turbopack",
    "dev:emulators:with-data": "firebase emulators:start --import=../.data/emulators/firebase-data --only auth,firestore",
    "emulators:export": "firebase emulators:export ../.data/emulators/firebase-data",
    "check:emulators": "wait-on -l tcp:4400 -t 5000 && echo 'Emulator Hub is available!'",
    "build": "next build",
    "build:profile": "next build --profile",
    "start": "next start",
    "lint": "next lint --strict",
    "lint:fix": "next lint --strict --fix",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:unit:watch": "vitest --watch --exclude '**/*.integration.test.ts'"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.10",
    "@decision-copilot/domain": "workspace:*",
    "@decision-copilot/infrastructure": "workspace:*",
    "@decision-copilot/ui": "workspace:*",
    "@google-cloud/functions-framework": "^3.4.5",
    "@hookform/resolvers": "^4.1.3",
    "@tiptap/html": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "firebase": "^11.3.1",
    "firebase-admin": "^12.7.0",
    "firebase-frameworks": "^0.11.6",
    "firebase-functions": "^6.3.2",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.473.0",
    "next": "15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.1",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^2.6.0",
    "tiptap-markdown": "^0.8.10",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@decision-copilot/config-eslint": "workspace:*",
    "@decision-copilot/config-typescript": "workspace:*",
    "@decision-copilot/test-utils": "workspace:*",
    "@eslint/eslintrc": "^3.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.20.0",
    "concurrently": "^9.1.2",
    "eslint-config-next": "15.1.5",
    "eslint-plugin-only-warn": "^1.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "wait-on": "^8.0.3"
  }
}