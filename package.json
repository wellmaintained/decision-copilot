{
  "name": "decision-copilot-monorepo",
  "version": "0.5.0",
  "description": "Decision Copilot Turborepo Monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:unit:watch": "turbo test:unit:watch",
    "test:watch": "turbo test:watch",
    "clean": "turbo clean",
    "pre:push": "turbo pre:push",
    "dev:emulators:with-data": "cd apps/webapp && pnpm run dev:emulators:with-data",
    "emulators:export": "cd apps/webapp && pnpm run emulators:export"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.6"
}