{
  "name": "decision-copilot-monorepo",
  "version": "0.5.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "pre:push": "turbo run pre:push",
    "dev": "turbo run dev",
    "dev:webapp": "turbo run dev --filter=webapp",
    "dev:mcp-api": "turbo run dev --filter=mcp-api",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:watch": "turbo run test:watch",
    "test:unit:watch": "turbo run test:unit:watch",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "clean": "turbo run clean",
    "firebase": "firebase",
    "migrate": "tsx scripts/migrate.ts",
    "firebase:apphosting:deploy:staging": "firebase apphosting:rollouts:create staging --project decision-copilot",
    "firebase:apphosting:deploy:prod": "firebase apphosting:rollouts:create prod --project decision-copilot"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitest/coverage-v8": "^3.0.9",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "firebase-tools": "^13.31.2",
    "husky": "^9.0.11",
    "tsx": "^4.19.3",
    "turbo": "^2.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}