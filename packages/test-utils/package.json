{
  "name": "@decision-copilot/test-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Shared test utilities and fixtures for decision-copilot monorepo",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js",
    "./*": "./lib/*.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf lib",
    "pre:push": "pnpm run lint && pnpm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@decision-copilot/config-eslint": "workspace:*",
    "@decision-copilot/config-typescript": "workspace:*",
    "@types/uuid": "^10.0.0"
  },
  "peerDependencies": {
    "vitest": "^3.0.9"
  }
}